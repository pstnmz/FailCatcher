{
  "source": "AMOS_2022",
  "description": "AMOS CT-only dataset (ID < 500) - ONE IMAGE PER ORGAN per patient",
  "preprocessing": {
    "hu_window_min": -135,
    "hu_window_max": 215,
    "target_size": [
      224,
      224
    ],
    "interpolation": "bilinear",
    "slice_selection": "best_axial_slice_with_maximum_organ_area",
    "bounding_box": "square_2D_bbox_after_slice_selection",
    "note": "Process: 0) HU\u2192grayscale on ENTIRE volume, 1) Find slice with max organ area, 2) Crop square bbox in 2D, 3) Resize to 224x224",
    "important": "HU windowing applied to entire image BEFORE cropping for consistent intensity across all organs"
  },
  "modality": "CT",
  "id_filter": "ID < 500 (CT scans only, MRI excluded)",
  "n_samples": 4454,
  "n_patients": 300,
  "n_failed": 0,
  "n_skipped_organs": 0,
  "splits_merged": [
    "training",
    "validation"
  ],
  "organ_labels": {
    "0": "spleen",
    "1": "right kidney",
    "2": "left kidney",
    "3": "gall bladder",
    "4": "esophagus",
    "5": "liver",
    "6": "stomach",
    "7": "aorta",
    "8": "postcava",
    "9": "pancreas",
    "10": "right adrenal gland",
    "11": "left adrenal gland",
    "12": "duodenum",
    "13": "bladder",
    "14": "prostate/uterus"
  }
}